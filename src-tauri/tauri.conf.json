{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Notepad",
  "version": "0.5.0",
  "identifier": "com.huntzzz.desktop-notepad",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop Notepad",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.deepseek.com https://api.siliconflow.cn https://openrouter.ai https://api.mimo.com https://v1.hitokoto.cn https://api.tavily.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": [],
      "databases": {
        "sqlite": {
          "path": "desktop-notepad.db"
        }
      }
    }
  }
}
